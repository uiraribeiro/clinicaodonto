{
    "name": "odonto/scheduler",
    "description": "Sistema de agendamento de clínica e laboratório odontológico universitário",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.13",
        "slim/twig-view": "^3.4",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "slim/psr7": "^1.6",
        "vlucas/phpdotenv": "^5.6",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^2.1",
        "predis/predis": "^2.2",
        "firebase/php-jwt": "^6.10",
        "monolog/monolog": "^3.5",
        "respect/validation": "^2.3",
        "nesbot/carbon": "^3.0",
        "aws/aws-sdk-php": "^3.300"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "test": "phpunit --colors=always",
        "analyse": "phpstan analyse src --level=6",
        "cs": "phpcs --standard=PSR12 src/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
