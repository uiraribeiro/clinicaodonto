# =============================================================================
# ODONTO SCHEDULER — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commitar o .env com valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
APP_NAME="Odonto Scheduler"
APP_ENV=development        # development | production
APP_DEBUG=true             # false em produção (NUNCA true em produção)
APP_URL=http://localhost:8080
APP_SECRET=TROQUE_AQUI_POR_STRING_ALEATORIA_DE_32_CARACTERES_OU_MAIS

# Timezone do servidor
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# -----------------------------------------------------------------------------
# Banco de Dados MySQL
# -----------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=odonto_scheduler
DB_USER=odonto_user
DB_PASSWORD=TROQUE_AQUI_SENHA_FORTE_DO_BANCO
DB_CHARSET=utf8mb4

# Usuário root (usado apenas no boot inicial via docker)
DB_ROOT_PASSWORD=TROQUE_AQUI_SENHA_ROOT_MYSQL

# -----------------------------------------------------------------------------
# Redis (cache e rate limiting)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=300        # segundos — TTL do cache Bedrock

# -----------------------------------------------------------------------------
# Amazon Bedrock
# -----------------------------------------------------------------------------
# Opção 1: Credenciais explícitas (desenvolvimento local)
AWS_ACCESS_KEY_ID=COLOQUE_SUA_ACCESS_KEY_AQUI
AWS_SECRET_ACCESS_KEY=COLOQUE_SUA_SECRET_KEY_AQUI
AWS_SESSION_TOKEN=         # deixe vazio se não usar role temporária

# Opção 2: Em EC2/ECS, deixe as três linhas acima em branco
# e configure uma IAM Role com permissão bedrock:InvokeModel

AWS_BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.3    # baixo = mais determinístico para sugestões

# Habilita/desabilita integração Bedrock (false = usa só o otimizador)
BEDROCK_ENABLED=true

# -----------------------------------------------------------------------------
# Sessão e Segurança
# -----------------------------------------------------------------------------
SESSION_LIFETIME=7200      # segundos (2 horas)
SESSION_NAME=odonto_sess

# Brute force protection
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
LOG_LEVEL=debug            # debug | info | warning | error
LOG_CHANNEL=file           # file | stderr
LOG_PATH=storage/logs/app.log

# -----------------------------------------------------------------------------
# Email (notificações ao publicar agenda)
# -----------------------------------------------------------------------------
MAIL_DRIVER=smtp           # smtp | sendmail | log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@suauniversidade.edu.br
MAIL_PASSWORD=SENHA_DO_EMAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Odonto Scheduler"
MAIL_FROM_ADDRESS=noreply@suauniversidade.edu.br

# -----------------------------------------------------------------------------
# Exportação
# -----------------------------------------------------------------------------
EXPORT_PATH=storage/exports
EXPORT_MAX_AGE_HOURS=24    # arquivos mais antigos são removidos

# -----------------------------------------------------------------------------
# Configurações acadêmicas padrão
# -----------------------------------------------------------------------------
SEMESTER_WEEKS=20
CLINIC_CHAIRS=15
CLINIC_STUDENTS_PER_CHAIR=2
LAB_SEATS=30
