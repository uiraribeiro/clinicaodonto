<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Erro interno · {{ app_name }}</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #f8fafc; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .box { text-align: center; max-width: 480px; padding: 2rem; }
        .code { font-size: 5rem; font-weight: 900; color: #d1d5db; line-height: 1; }
        .icon { font-size: 3.5rem; margin-bottom: .5rem; }
        h1 { font-size: 1.5rem; font-weight: 700; color: #111827; margin: 0 0 .5rem; }
        p { color: #6b7280; margin: 0 0 1.5rem; }
        a { display: inline-block; padding: .55rem 1.5rem; background: #1a56db; color: #fff; border-radius: 8px; text-decoration: none; font-weight: 600; }
        a:hover { background: #1e40af; }
        details { text-align: left; margin-top: 1.5rem; background: #1e293b; color: #e2e8f0; border-radius: 8px; padding: 1rem; font-family: monospace; font-size: .75rem; overflow: auto; max-height: 300px; }
        summary { cursor: pointer; color: #94a3b8; margin-bottom: .5rem; }
        pre { margin: 0; white-space: pre-wrap; word-break: break-all; }
    </style>
</head>
<body>
    <div class="box">
        <div class="icon">⚙️</div>
        <div class="code">500</div>
        <h1>Erro interno do servidor</h1>
        <p>{{ mensagem }}</p>
        <a href="/">Voltar ao início</a>

        {% if debug_mensagem is defined %}
        <details>
            <summary>Detalhes do erro (visível apenas em modo debug)</summary>
            <pre>{{ debug_mensagem }}

{{ debug_arquivo }}

{{ debug_trace }}</pre>
        </details>
        {% endif %}
    </div>
</body>
</html>
