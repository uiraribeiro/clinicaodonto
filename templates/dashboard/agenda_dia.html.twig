{% extends "layout/base.html.twig" %}

{% block title %}Agenda do Dia — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
<li class="breadcrumb-item active">{{ data_atual|date('d/m/Y') }}</li>
{% endblock %}

{% block content %}
<div x-data="agendaDia()">

    <!-- Cabeçalho + seletor de data -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <div>
            <h4 class="mb-0 fw-bold"><i class="bi bi-calendar-day me-2 text-primary"></i>Agenda do Dia</h4>
            <small class="text-muted">{{ data_atual|date('l, d \\d\\e F \\d\\e Y') }}</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            {% set ontem = data_atual|date_modify('-1 day')|date('Y-m-d') %}
            {% set amanha = data_atual|date_modify('+1 day')|date('Y-m-d') %}
            <a href="?data={{ ontem }}" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-chevron-left"></i>
            </a>
            <form method="GET" class="d-flex gap-1">
                <input type="date" name="data" value="{{ data_atual }}" class="form-control form-control-sm" style="width:150px">
                <button type="submit" class="btn btn-sm btn-primary">Ir</button>
            </form>
            <a href="?data={{ amanha }}" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-chevron-right"></i>
            </a>
            <a href="?data={{ 'now'|date('Y-m-d') }}" class="btn btn-sm btn-outline-primary">Hoje</a>
        </div>
    </div>

    <!-- Indicadores de ocupação do dia -->
    <div class="row g-3 mb-4">
        <!-- Clínica -->
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-2">
                    <i class="bi bi-hospital me-2"></i>Ocupação da Clínica
                </div>
                <div class="card-body">
                    {% set max_clinica = 30 %}
                    {% set total_clinica = 0 %}
                    {% for oc in ocupacao_clinica %}
                        {% set total_clinica = total_clinica + oc.total_alunos %}
                    {% endfor %}
                    {% set pct_clinica = max_clinica > 0 ? (total_clinica / max_clinica * 100)|round : 0 %}

                    <div class="d-flex justify-content-between mb-1">
                        <span class="small">{{ total_clinica }} / {{ max_clinica }} alunos</span>
                        <span class="fw-bold {{ pct_clinica >= 90 ? 'text-danger' : (pct_clinica >= 70 ? 'text-warning' : 'text-success') }}">
                            {{ pct_clinica }}%
                        </span>
                    </div>
                    <div class="progress mb-3" style="height:8px">
                        <div class="progress-bar {{ pct_clinica >= 90 ? 'bg-danger' : (pct_clinica >= 70 ? 'bg-warning' : 'bg-success') }}"
                             style="width:{{ pct_clinica }}%"></div>
                    </div>

                    {% if ocupacao_clinica %}
                    <div class="small">
                        <strong>Por horário:</strong>
                        {% for oc in ocupacao_clinica %}
                        <div class="d-flex justify-content-between text-muted mt-1">
                            <span>{{ oc.hora_inicio|slice(0,5) }}–{{ oc.hora_fim|slice(0,5) }}</span>
                            <span>
                                {{ oc.total_alunos }} alunos
                                ({{ (oc.total_alunos / 2)|ceil }} cadeiras)
                            </span>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <p class="text-muted small mb-0">Sem atividades na clínica hoje.</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Laboratório -->
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info text-dark py-2">
                    <i class="bi bi-mortarboard me-2"></i>Ocupação do Laboratório
                </div>
                <div class="card-body">
                    {% set max_lab = 30 %}
                    {% set total_lab = 0 %}
                    {% for oc in ocupacao_lab %}
                        {% set total_lab = total_lab + oc.total_alunos %}
                    {% endfor %}
                    {% set pct_lab = max_lab > 0 ? (total_lab / max_lab * 100)|round : 0 %}

                    <div class="d-flex justify-content-between mb-1">
                        <span class="small">{{ total_lab }} / {{ max_lab }} assentos</span>
                        <span class="fw-bold {{ pct_lab >= 90 ? 'text-danger' : (pct_lab >= 70 ? 'text-warning' : 'text-success') }}">
                            {{ pct_lab }}%
                        </span>
                    </div>
                    <div class="progress mb-3" style="height:8px">
                        <div class="progress-bar bg-info" style="width:{{ pct_lab }}%"></div>
                    </div>

                    {% if ocupacao_lab %}
                    <div class="small">
                        <strong>Por horário:</strong>
                        {% for oc in ocupacao_lab %}
                        <div class="d-flex justify-content-between text-muted mt-1">
                            <span>{{ oc.hora_inicio|slice(0,5) }}–{{ oc.hora_fim|slice(0,5) }}</span>
                            <span>{{ oc.total_alunos }} alunos</span>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <p class="text-muted small mb-0">Sem atividades no laboratório hoje.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Lista detalhada de aulas do dia -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between">
            <h6 class="mb-0 fw-bold"><i class="bi bi-list-check me-2"></i>Atividades de Hoje</h6>
            <span class="badge bg-secondary">{{ agenda_dia|length }} atividade(s)</span>
        </div>

        {% if agenda_dia is empty %}
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-calendar-check fs-2 d-block mb-2"></i>
            Nenhuma atividade agendada para {{ data_atual|date('d/m/Y') }}.
        </div>
        {% else %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:110px">Horário</th>
                        <th>Espaço</th>
                        <th>Turma</th>
                        <th>Disciplina</th>
                        <th>Responsável</th>
                        <th class="text-center">Alunos</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                {% for ag in agenda_dia %}
                <tr>
                    <td class="fw-semibold text-nowrap">
                        {{ ag.hora_inicio|slice(0,5) }}<br>
                        <small class="text-muted">{{ ag.hora_fim|slice(0,5) }}</small>
                    </td>
                    <td>
                        <span class="badge {{ ag.espaco_tipo == 'clinica' ? 'bg-primary' : 'bg-info text-dark' }}">
                            <i class="bi {{ ag.espaco_tipo == 'clinica' ? 'bi-hospital' : 'bi-mortarboard' }} me-1"></i>
                            {{ ag.espaco_tipo == 'clinica' ? 'Clínica' : 'Lab' }}
                        </span>
                    </td>
                    <td class="fw-semibold">{{ ag.turma_nome|e }}</td>
                    <td>
                        <span title="{{ ag.disciplina_nome|e }}">{{ ag.disciplina_nome|e|slice(0,30) }}{% if ag.disciplina_nome|length > 30 %}…{% endif %}</span>
                    </td>
                    <td>
                        {% if ag.professor_nome %}
                        <i class="bi bi-person-badge me-1 text-muted"></i>{{ ag.professor_nome|e }}
                        {% elseif ag.preceptor_nome %}
                        <i class="bi bi-person-check me-1 text-muted"></i>{{ ag.preceptor_nome|e }}
                        {% else %}
                        <span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Sem responsável</span>
                        {% endif %}
                    </td>
                    <td class="text-center">
                        <span class="badge {{ ag.num_alunos > 25 ? 'bg-warning text-dark' : 'bg-secondary' }}">
                            {{ ag.num_alunos }}
                        </span>
                    </td>
                    <td>
                        {% set status_map = {agendado:'secondary',confirmado:'success',cancelado:'danger',realizado:'primary'} %}
                        <span class="badge bg-{{ status_map[ag.status] ?? 'secondary' }}">
                            {{ ag.status|capitalize }}
                        </span>
                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>

</div>
{% endblock %}

{% block scripts %}
<script>
function agendaDia() { return {} }
</script>
{% endblock %}
