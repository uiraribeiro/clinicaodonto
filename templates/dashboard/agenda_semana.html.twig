{% extends "layout/base.html.twig" %}

{% block title %}Agenda Semanal — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
<li class="breadcrumb-item active">Semana {{ semana_atual }}</li>
{% endblock %}

{% block content %}
<div x-data="agendaSemana()" x-init="init()">

    <!-- Cabeçalho + navegação -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <div>
            <h4 class="mb-0 fw-bold"><i class="bi bi-calendar-week me-2 text-primary"></i>Agenda Semanal</h4>
            <small class="text-muted">Semana {{ semana_atual }} de 20</small>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a href="?semana={{ semana_atual > 1 ? semana_atual - 1 : 1 }}"
               class="btn btn-sm btn-outline-secondary {{ semana_atual <= 1 ? 'disabled' : '' }}">
                <i class="bi bi-chevron-left"></i> Anterior
            </a>
            <span class="badge bg-primary fs-6 px-3">Semana {{ semana_atual }}</span>
            <a href="?semana={{ semana_atual < 20 ? semana_atual + 1 : 20 }}"
               class="btn btn-sm btn-outline-secondary {{ semana_atual >= 20 ? 'disabled' : '' }}">
                Próxima <i class="bi bi-chevron-right"></i>
            </a>
            <a href="/dashboard/dia" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-calendar-day me-1"></i>Ver dia
            </a>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="GET" class="row g-2 align-items-center">
                <input type="hidden" name="semana" value="{{ semana_atual }}">
                <div class="col-6 col-md-2">
                    <select name="espaco" class="form-select form-select-sm">
                        <option value="">Todos os espaços</option>
                        <option value="clinica"      {{ filtros.espaco ?? '' == 'clinica' ? 'selected' : '' }}>Clínica</option>
                        <option value="laboratorio"  {{ filtros.espaco ?? '' == 'laboratorio' ? 'selected' : '' }}>Laboratório</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <input type="text" name="turma_nome" class="form-control form-control-sm"
                           placeholder="Turma..." value="{{ filtros.turma_nome ?? '' }}">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-funnel me-1"></i>Filtrar
                    </button>
                    <a href="?semana={{ semana_atual }}" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Limpar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Legenda -->
    <div class="d-flex gap-3 mb-3 flex-wrap">
        <span class="small"><span class="badge bg-primary me-1">&nbsp;</span>Clínica</span>
        <span class="small"><span class="badge bg-info text-dark me-1">&nbsp;</span>Laboratório</span>
        <span class="small"><span class="badge bg-success me-1">&nbsp;</span>Estágio</span>
        <span class="small"><span class="badge bg-danger me-1">&nbsp;</span>Conflito</span>
    </div>

    {% if agenda_semana is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
            Nenhum agendamento para a semana {{ semana_atual }}.
            <div class="mt-3">
                <a href="/agenda/gerar" class="btn btn-primary">
                    <i class="bi bi-magic me-2"></i>Gerar Agenda Semestral
                </a>
            </div>
        </div>
    </div>
    {% else %}

    {# Agrupa por dia da semana #}
    {% set dias_labels = {1:'Segunda', 2:'Terça', 3:'Quarta', 4:'Quinta', 5:'Sexta', 6:'Sábado'} %}
    {% set por_dia = {} %}
    {% for ag in agenda_semana %}
        {% set dia = ag.dia_semana %}
        {% if por_dia[dia] is not defined %}
            {% set por_dia = por_dia|merge({(dia): []}) %}
        {% endif %}
        {% set por_dia = por_dia|merge({(dia): por_dia[dia]|merge([ag])}) %}
    {% endfor %}

    <div class="row g-3">
        {% for dia_num, label in dias_labels %}
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header py-2 {{ loop.first ? 'bg-primary text-white' : 'bg-light' }}">
                    <span class="fw-semibold">{{ label }}</span>
                    {% if por_dia[dia_num] is defined %}
                    <span class="badge {{ loop.first ? 'bg-light text-primary' : 'bg-secondary' }} ms-2">
                        {{ por_dia[dia_num]|length }} aula(s)
                    </span>
                    {% endif %}
                </div>
                <div class="card-body p-2">
                    {% if por_dia[dia_num] is defined and por_dia[dia_num] %}
                        {% for ag in por_dia[dia_num] %}
                        <div class="rounded p-2 mb-2 {{ ag.espaco_tipo == 'clinica' ? 'slot-clinica' : 'slot-laboratorio' }}">
                            <div class="d-flex justify-content-between align-items-start">
                                <strong class="small">{{ ag.hora_inicio|slice(0,5) }}–{{ ag.hora_fim|slice(0,5) }}</strong>
                                <span class="badge {{ ag.espaco_tipo == 'clinica' ? 'bg-light text-primary' : 'bg-dark' }} ms-1" style="font-size:.65rem">
                                    {{ ag.espaco_tipo == 'clinica' ? 'Clínica' : 'Lab' }}
                                </span>
                            </div>
                            <div class="small mt-1 fw-semibold">{{ ag.turma_nome|e }}</div>
                            <div class="small text-truncate" style="opacity:.85">{{ ag.disciplina_nome|e }}</div>
                            <div class="small mt-1" style="opacity:.75">
                                <i class="bi bi-person me-1"></i>
                                {{ (ag.professor_nome ?? ag.preceptor_nome ?? 'Sem responsável')|e }}
                                &nbsp;·&nbsp;
                                <i class="bi bi-people me-1"></i>{{ ag.num_alunos }} alunos
                            </div>
                        </div>
                        {% endfor %}
                    {% else %}
                        <div class="text-center text-muted py-3 small">
                            <i class="bi bi-dash-circle me-1"></i>Sem aulas
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    <!-- Resumo da semana (dados pré-computados pelo controller) -->
    {% if agenda_semana is not empty and resumo is defined %}
    <div class="row g-3 mt-2">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Resumo da Semana {{ semana_atual }}</h6>
                    <div class="row text-center g-3">
                        <div class="col-6 col-md-3">
                            <div class="fs-4 fw-bold text-primary">{{ resumo.total_slots }}</div>
                            <div class="small text-muted">Total de slots</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="fs-4 fw-bold text-info">{{ resumo.slots_lab }}</div>
                            <div class="small text-muted">Slots de laboratório</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="fs-4 fw-bold text-success">{{ resumo.total_alunos }}</div>
                            <div class="small text-muted">Total alunos alocados</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="fs-4 fw-bold text-secondary">{{ resumo.turmas_count }}</div>
                            <div class="small text-muted">Turmas diferentes</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}

{% block scripts %}
<script>
function agendaSemana() {
    return { init() {} }
}
</script>
{% endblock %}
