{% extends "layout/base.html.twig" %}

{% block title %}Relatório por Professor / Preceptor — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="/relatorios">Relatórios</a></li>
<li class="breadcrumb-item active">Por Professor / Preceptor</li>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2 text-warning"></i>Carga de Professores e Preceptores</h4>
        <small class="text-muted">Versão #{{ versao.numero_versao }} · {{ versao.semestre_ref }}</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/relatorios/exportar/professor/pdf" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-filetype-pdf me-1"></i>PDF
        </a>
        <a href="/relatorios/exportar/professor/xlsx" class="btn btn-sm btn-outline-success">
            <i class="bi bi-file-earmark-excel me-1"></i>Excel
        </a>
        <a href="/relatorios/exportar/professor/csv" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-filetype-csv me-1"></i>CSV
        </a>
        <a href="/relatorios" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Voltar
        </a>
    </div>
</div>

{# Professores #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent fw-semibold py-2">
        <i class="bi bi-person-workspace me-2 text-primary"></i>Professores
        <span class="badge bg-primary ms-2">{{ professores|length }}</span>
    </div>
    {% if professores is empty %}
        <div class="card-body text-center text-muted py-4">Nenhum professor cadastrado.</div>
    {% else %}
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th class="text-center">Turmas</th>
                    <th class="text-center">Disciplinas</th>
                    <th class="text-end">Slots</th>
                    <th class="text-end">Horas</th>
                    <th class="text-center">Dias com Aula</th>
                </tr>
            </thead>
            <tbody>
            {% for p in professores %}
                <tr>
                    <td><strong>{{ p.nome }}</strong></td>
                    <td class="small text-muted">{{ p.email }}</td>
                    <td class="text-center">{{ p.turmas }}</td>
                    <td class="text-center">{{ p.disciplinas }}</td>
                    <td class="text-end fw-bold">{{ p.total_slots }}</td>
                    <td class="text-end">
                        {% set h = p.total_horas %}
                        {% if h > 0 %}
                            <strong>{{ h|number_format(1) }}h</strong>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td class="text-center">
                        {% if p.dias_com_aula > 0 %}
                            <span class="badge bg-primary-subtle text-primary border">{{ p.dias_com_aula }} dias</span>
                        {% else %}
                            <span class="text-muted small">Sem aulas</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>

{# Preceptores #}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent fw-semibold py-2">
        <i class="bi bi-person-badge me-2 text-success"></i>Preceptores
        <span class="badge bg-success ms-2">{{ preceptores|length }}</span>
    </div>
    {% if preceptores is empty %}
        <div class="card-body text-center text-muted py-4">Nenhum preceptor cadastrado.</div>
    {% else %}
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th class="text-center">Max Turm. Simult.</th>
                    <th class="text-center">Turmas</th>
                    <th class="text-center">Disciplinas</th>
                    <th class="text-end">Slots</th>
                    <th class="text-end">Horas</th>
                    <th class="text-center">Dias com Aula</th>
                </tr>
            </thead>
            <tbody>
            {% for p in preceptores %}
                {% set sobrecarga = p.turmas > p.max_turmas_simultaneas %}
                <tr {% if sobrecarga %}class="table-danger"{% endif %}>
                    <td>
                        <strong>{{ p.nome }}</strong>
                        {% if sobrecarga %}
                            <span class="badge bg-danger ms-1" title="Excede limite simultâneo">
                                <i class="bi bi-exclamation-triangle"></i>
                            </span>
                        {% endif %}
                    </td>
                    <td class="small text-muted">{{ p.email }}</td>
                    <td class="text-center">{{ p.max_turmas_simultaneas }}</td>
                    <td class="text-center {% if sobrecarga %}fw-bold text-danger{% endif %}">{{ p.turmas }}</td>
                    <td class="text-center">{{ p.disciplinas }}</td>
                    <td class="text-end fw-bold">{{ p.total_slots }}</td>
                    <td class="text-end">
                        {% if p.total_horas > 0 %}
                            <strong>{{ p.total_horas|number_format(1) }}h</strong>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td class="text-center">
                        {% if p.dias_com_aula > 0 %}
                            <span class="badge bg-success-subtle text-success border">{{ p.dias_com_aula }} dias</span>
                        {% else %}
                            <span class="text-muted small">Sem aulas</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}
