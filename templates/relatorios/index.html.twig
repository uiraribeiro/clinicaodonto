{% extends "layout/base.html.twig" %}

{% block title %}Relatórios — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item active">Relatórios</li>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-bar-chart me-2 text-primary"></i>Relatórios</h4>
        <small class="text-muted">Exportações disponíveis: PDF, Excel e CSV</small>
    </div>
</div>

<div class="row g-3">

    <!-- Por Semana -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-calendar-week fs-3 text-primary"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">Por Semana</h6>
                        <small class="text-muted">Ocupação semana a semana</small>
                    </div>
                </div>
                <p class="text-muted small">Visualiza todos os agendamentos de uma semana específica com ocupação de clínica e laboratório.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a href="/relatorios/semana" class="btn btn-sm btn-primary flex-grow-1">
                        <i class="bi bi-eye me-1"></i>Ver
                    </a>
                    <a href="/relatorios/exportar/semana/pdf" class="btn btn-sm btn-outline-danger">PDF</a>
                    <a href="/relatorios/exportar/semana/xlsx" class="btn btn-sm btn-outline-success">Excel</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Por Turma -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-people fs-3 text-success"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">Por Turma</h6>
                        <small class="text-muted">Carga horária e presença</small>
                    </div>
                </div>
                <p class="text-muted small">Mostra o total de horas alocadas, disciplinas e responsáveis para cada turma no semestre.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a href="/relatorios/turma" class="btn btn-sm btn-success flex-grow-1">
                        <i class="bi bi-eye me-1"></i>Ver
                    </a>
                    <a href="/relatorios/exportar/turma/pdf" class="btn btn-sm btn-outline-danger">PDF</a>
                    <a href="/relatorios/exportar/turma/xlsx" class="btn btn-sm btn-outline-success">Excel</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Por Disciplina -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-book fs-3 text-info"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">Por Disciplina</h6>
                        <small class="text-muted">Uso por disciplina</small>
                    </div>
                </div>
                <p class="text-muted small">Detalha quantas horas, turmas e alunos cada disciplina ocupa na clínica e no laboratório.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a href="/relatorios/disciplina" class="btn btn-sm btn-info flex-grow-1">
                        <i class="bi bi-eye me-1"></i>Ver
                    </a>
                    <a href="/relatorios/exportar/disciplina/pdf" class="btn btn-sm btn-outline-danger">PDF</a>
                    <a href="/relatorios/exportar/disciplina/xlsx" class="btn btn-sm btn-outline-success">Excel</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Por Professor -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-person-badge fs-3 text-warning"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">Por Professor / Preceptor</h6>
                        <small class="text-muted">Carga de trabalho</small>
                    </div>
                </div>
                <p class="text-muted small">Exibe horas alocadas, turmas atendidas e potenciais sobrecargas de cada professor ou preceptor.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a href="/relatorios/professor" class="btn btn-sm btn-warning flex-grow-1">
                        <i class="bi bi-eye me-1"></i>Ver
                    </a>
                    <a href="/relatorios/exportar/professor/pdf" class="btn btn-sm btn-outline-danger">PDF</a>
                    <a href="/relatorios/exportar/professor/xlsx" class="btn btn-sm btn-outline-success">Excel</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Por Espaço -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-hospital fs-3 text-danger"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">Por Espaço</h6>
                        <small class="text-muted">Uso de clínica e laboratório</small>
                    </div>
                </div>
                <p class="text-muted small">Percentual de ocupação, horários ociosos e gargalos da clínica e do laboratório ao longo do semestre.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a href="/relatorios/espaco" class="btn btn-sm btn-danger flex-grow-1">
                        <i class="bi bi-eye me-1"></i>Ver
                    </a>
                    <a href="/relatorios/exportar/espaco/pdf" class="btn btn-sm btn-outline-danger">PDF</a>
                    <a href="/relatorios/exportar/espaco/xlsx" class="btn btn-sm btn-outline-success">Excel</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Exportação CSV -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-filetype-csv fs-3 text-secondary"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">Exportação Completa</h6>
                        <small class="text-muted">Dados brutos em CSV</small>
                    </div>
                </div>
                <p class="text-muted small">Exporta todos os agendamentos do semestre em formato CSV para processamento em planilhas externas.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a href="/relatorios/exportar/completo/csv" class="btn btn-sm btn-secondary flex-grow-1">
                        <i class="bi bi-download me-1"></i>Baixar CSV
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>

{% if versao %}
<div class="alert alert-success mt-4 d-flex gap-2 align-items-start">
    <i class="bi bi-check-circle-fill fs-5 flex-shrink-0 mt-1"></i>
    <div>
        <strong>Versão ativa:</strong> #{{ versao.numero_versao }} — {{ versao.semestre_ref }}
        <span class="badge bg-success ms-2">{{ versao.status }}</span>
        <span class="text-muted small ms-2">Clique em <em>Ver</em> ou baixe diretamente nos formatos disponíveis.</span>
    </div>
</div>
{% else %}
<div class="alert alert-warning mt-4 d-flex gap-2 align-items-start">
    <i class="bi bi-exclamation-triangle fs-5 flex-shrink-0 mt-1"></i>
    <div>
        <strong>Nenhuma agenda publicada.</strong>
        <a href="/agenda" class="ms-1">Gere e publique uma versão de agenda</a> para habilitar os relatórios.
    </div>
</div>
{% endif %}
{% endblock %}
