{% extends "layout/base.html.twig" %}

{% block title %}Relatório por Disciplina — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="/relatorios">Relatórios</a></li>
<li class="breadcrumb-item active">Por Disciplina</li>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-book me-2 text-info"></i>Uso por Disciplina</h4>
        <small class="text-muted">Versão #{{ versao.numero_versao }} · {{ versao.semestre_ref }} · {{ resumo|length }} disciplina(s)</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/relatorios/exportar/disciplina/pdf" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-filetype-pdf me-1"></i>PDF
        </a>
        <a href="/relatorios/exportar/disciplina/xlsx" class="btn btn-sm btn-outline-success">
            <i class="bi bi-file-earmark-excel me-1"></i>Excel
        </a>
        <a href="/relatorios/exportar/disciplina/csv" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-filetype-csv me-1"></i>CSV
        </a>
        <a href="/relatorios" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Voltar
        </a>
    </div>
</div>

{% set t_slots = 0 %}{% set t_horas = 0 %}{% set t_clinica = 0 %}{% set t_lab = 0 %}{% set t_alunos = 0 %}
{% for d in resumo %}
    {% set t_slots   = t_slots   + d.total_slots %}
    {% set t_horas   = t_horas   + d.total_horas %}
    {% set t_clinica = t_clinica + d.slots_clinica %}
    {% set t_lab     = t_lab     + d.slots_lab %}
    {% set t_alunos  = t_alunos  + d.total_alunos_x_slot %}
{% endfor %}

{% if resumo is empty %}
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body text-muted">
            <i class="bi bi-book fs-1 d-block mb-3"></i>
            Nenhuma disciplina encontrada.
        </div>
    </div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Disciplina</th>
                    <th class="text-center">Tipo</th>
                    <th class="text-center">Duração</th>
                    <th class="text-center">Turmas</th>
                    <th class="text-end">Total Slots</th>
                    <th class="text-end">Horas</th>
                    <th class="text-end">Slots Clínica</th>
                    <th class="text-end">Slots Lab</th>
                    <th class="text-end">Alunos×Slot</th>
                </tr>
            </thead>
            <tbody>
            {% set tipo_atual = null %}
            {% for d in resumo %}
                {% if d.tipo != tipo_atual %}
                    {% set tipo_atual = d.tipo %}
                    <tr class="table-secondary">
                        <td colspan="10" class="fw-semibold small text-uppercase ps-3">
                            <i class="bi bi-tag me-1"></i>{{ tipo_atual|capitalize }}
                        </td>
                    </tr>
                {% endif %}
                <tr>
                    <td class="font-monospace small">{{ d.codigo }}</td>
                    <td><strong>{{ d.nome }}</strong></td>
                    <td class="text-center">
                        {% if d.tipo == 'clinica' %}
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Clínica</span>
                        {% elseif d.tipo == 'laboratorio' %}
                            <span class="badge bg-success-subtle text-success border border-success-subtle">Lab</span>
                        {% else %}
                            <span class="badge bg-secondary-subtle text-secondary border">{{ d.tipo }}</span>
                        {% endif %}
                    </td>
                    <td class="text-center small">{{ d.duracao_encontro_min }} min</td>
                    <td class="text-center">{{ d.total_turmas }}</td>
                    <td class="text-end fw-bold">{{ d.total_slots }}</td>
                    <td class="text-end">{{ d.total_horas|number_format(1) }}h</td>
                    <td class="text-end text-primary">{{ d.slots_clinica }}</td>
                    <td class="text-end text-success">{{ d.slots_lab }}</td>
                    <td class="text-end">{{ d.total_alunos_x_slot }}</td>
                </tr>
            {% endfor %}
            </tbody>
            <tfoot class="table-light fw-bold">
                <tr>
                    <td colspan="5" class="text-end small">TOTAL</td>
                    <td class="text-end">{{ t_slots }}</td>
                    <td class="text-end">{{ t_horas|number_format(1) }}h</td>
                    <td class="text-end text-primary">{{ t_clinica }}</td>
                    <td class="text-end text-success">{{ t_lab }}</td>
                    <td class="text-end">{{ t_alunos }}</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
