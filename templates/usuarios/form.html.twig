{% extends "layout/base.html.twig" %}

{% block title %}{{ modo == 'criar' ? 'Novo Usuário' : 'Editar Usuário' }} — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item">Administração</li>
<li class="breadcrumb-item"><a href="/usuarios">Usuários</a></li>
<li class="breadcrumb-item active">{{ modo == 'criar' ? 'Novo' : 'Editar' }}</li>
{% endblock %}

{% block content %}
<div class="row justify-content-center">
<div class="col-12 col-xl-8">

    {# ── Cabeçalho ─────────────────────────────────────────────────────────── #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-person-gear me-2 text-primary"></i>
            {{ modo == 'criar' ? 'Novo Usuário' : 'Editar: ' ~ usuario.nome|e }}
        </h4>
        <a href="/usuarios" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Voltar
        </a>
    </div>

    {# ── Erros ─────────────────────────────────────────────────────────────── #}
    {% if errors is defined and errors %}
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Corrija os erros abaixo antes de continuar:</strong>
        <ul class="mb-0 mt-2">
            {% for field, msg in errors %}
            <li>{{ msg|e }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    {# ── Formulário ────────────────────────────────────────────────────────── #}
    <form
        action="{{ modo == 'criar' ? '/usuarios' : '/usuarios/' ~ usuario.id }}"
        method="POST"
        novalidate
    >
        {# CSRF obrigatório #}
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">

                {# ── Dados pessoais ──────────────────────────────────────── #}
                <h6 class="fw-bold text-primary mb-3">Dados do Usuário</h6>
                <div class="row g-3 mb-4">

                    {# Nome #}
                    <div class="col-12">
                        <label for="nome" class="form-label fw-semibold">
                            Nome completo <span class="text-danger">*</span>
                        </label>
                        <input
                            type="text"
                            id="nome"
                            name="nome"
                            class="form-control {{ errors.nome is defined ? 'is-invalid' : '' }}"
                            value="{{ usuario.nome|default('')|e }}"
                            maxlength="200"
                            placeholder="Ex: Maria Silva"
                            required
                        >
                        {% if errors.nome is defined %}
                        <div class="invalid-feedback">{{ errors.nome|e }}</div>
                        {% endif %}
                    </div>

                    {# E-mail #}
                    <div class="col-md-7">
                        <label for="email" class="form-label fw-semibold">
                            E-mail <span class="text-danger">*</span>
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            class="form-control {{ errors.email is defined ? 'is-invalid' : '' }}"
                            value="{{ usuario.email|default('')|e }}"
                            maxlength="255"
                            placeholder="usuario@exemplo.com"
                            required
                        >
                        {% if errors.email is defined %}
                        <div class="invalid-feedback">{{ errors.email|e }}</div>
                        {% endif %}
                    </div>

                    {# Perfil #}
                    <div class="col-md-5">
                        <label for="perfil_id" class="form-label fw-semibold">
                            Perfil <span class="text-danger">*</span>
                        </label>
                        <select
                            id="perfil_id"
                            name="perfil_id"
                            class="form-select {{ errors.perfil_id is defined ? 'is-invalid' : '' }}"
                            required
                        >
                            <option value="">Selecione um perfil...</option>
                            {% for perfil in perfis %}
                            <option
                                value="{{ perfil.id }}"
                                {{ usuario.perfil_id is defined and usuario.perfil_id == perfil.id ? 'selected' : '' }}
                            >
                                {{ perfil.nome|e }}
                            </option>
                            {% endfor %}
                        </select>
                        {% if errors.perfil_id is defined %}
                        <div class="invalid-feedback">{{ errors.perfil_id|e }}</div>
                        {% endif %}
                    </div>

                </div>

                {# ── Status (só no modo editar) ──────────────────────────── #}
                {% if modo == 'editar' %}
                <div class="mb-4">
                    <h6 class="fw-bold text-primary mb-3">Status da Conta</h6>
                    <div class="form-check form-switch">
                        <input
                            class="form-check-input"
                            type="checkbox"
                            id="ativo"
                            name="ativo"
                            value="1"
                            {{ usuario.ativo is defined and usuario.ativo ? 'checked' : '' }}
                        >
                        <label class="form-check-label" for="ativo">
                            Conta ativa
                        </label>
                        <div class="form-text">
                            Desmarque para inativar o acesso do usuário sem excluí-lo.
                        </div>
                    </div>
                </div>
                {% endif %}

                {# ── Senha ───────────────────────────────────────────────── #}
                <div>
                    <h6 class="fw-bold text-primary mb-3">
                        {% if modo == 'criar' %}
                            Senha <span class="text-danger">*</span>
                        {% else %}
                            Senha
                        {% endif %}
                    </h6>

                    {% if modo == 'editar' %}
                    <div class="alert alert-secondary py-2 small mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Deixe a senha em branco para manter a atual.
                    </div>
                    {% endif %}

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="senha" class="form-label fw-semibold">
                                {% if modo == 'criar' %}Nova senha{% else %}Nova senha (opcional){% endif %}
                            </label>
                            <input
                                type="password"
                                id="senha"
                                name="senha"
                                class="form-control {{ errors.senha is defined ? 'is-invalid' : '' }}"
                                minlength="8"
                                autocomplete="new-password"
                                placeholder="Mínimo 8 caracteres"
                                {{ modo == 'criar' ? 'required' : '' }}
                            >
                            {% if errors.senha is defined %}
                            <div class="invalid-feedback">{{ errors.senha|e }}</div>
                            {% endif %}
                            <div class="form-text">Mínimo de 8 caracteres.</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        {# ── Botões ────────────────────────────────────────────────────────── #}
        <div class="d-flex gap-2 justify-content-end">
            <a href="/usuarios" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>
                {{ modo == 'criar' ? 'Criar Usuário' : 'Salvar Alterações' }}
            </button>
        </div>

    </form>

</div>
</div>
{% endblock %}
