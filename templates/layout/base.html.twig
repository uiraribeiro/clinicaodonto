<!DOCTYPE html>
<html lang="pt-BR" x-data="{ sidebarOpen: true, darkMode: false }" :class="{ 'dark': darkMode }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token ?? '' }}">
    <title>{% block title %}{{ app_name }}{% endblock %}</title>

    <!-- Bootstrap 5.3 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- App CSS -->
    <link rel="stylesheet" href="{{ app_url }}/css/app.css">
    {% block head_extra %}{% endblock %}
</head>
<body class="bg-light">

<div class="d-flex">
    <!-- Sidebar -->
    <nav id="sidebar" class="sidebar bg-dark text-white d-flex flex-column"
         :class="{ 'sidebar-collapsed': !sidebarOpen }"
         x-show="sidebarOpen || window.innerWidth >= 768"
         x-transition>

        <div class="sidebar-header p-3 border-bottom border-secondary">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-tooth fs-4 text-info"></i>
                <span class="fw-bold fs-6" x-show="sidebarOpen">{{ app_name }}</span>
            </div>
        </div>

        <ul class="nav flex-column p-2 flex-grow-1">

            <li class="nav-item">
                <a href="/dashboard" class="nav-link text-white {% if active_menu == 'dashboard' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-speedometer2 me-2"></i>
                    <span x-show="sidebarOpen">Dashboard</span>
                </a>
            </li>

            <li class="nav-item mt-2">
                <small class="text-secondary px-2" x-show="sidebarOpen">AGENDA</small>
            </li>
            <li class="nav-item">
                <a href="/agenda" class="nav-link text-white {% if active_menu == 'agenda' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-calendar3 me-2"></i>
                    <span x-show="sidebarOpen">Agenda Semestral</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/ia/sugestoes/{{ semestre_id ?? '' }}" class="nav-link text-white {% if active_menu == 'ia' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-robot me-2"></i>
                    <span x-show="sidebarOpen">Sugestões IA</span>
                </a>
            </li>

            <li class="nav-item mt-2">
                <small class="text-secondary px-2" x-show="sidebarOpen">CADASTROS</small>
            </li>
            <li class="nav-item">
                <a href="/cadastros/disciplinas" class="nav-link text-white {% if active_menu == 'disciplinas' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-book me-2"></i>
                    <span x-show="sidebarOpen">Disciplinas</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/cadastros/professores" class="nav-link text-white {% if active_menu == 'professores' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-person-badge me-2"></i>
                    <span x-show="sidebarOpen">Professores</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/cadastros/preceptores" class="nav-link text-white {% if active_menu == 'preceptores' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-person-check me-2"></i>
                    <span x-show="sidebarOpen">Preceptores</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/cadastros/turmas" class="nav-link text-white {% if active_menu == 'turmas' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-people me-2"></i>
                    <span x-show="sidebarOpen">Turmas</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/cadastros/clinica" class="nav-link text-white {% if active_menu == 'clinica' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-hospital me-2"></i>
                    <span x-show="sidebarOpen">Clínica</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/cadastros/laboratorio" class="nav-link text-white {% if active_menu == 'laboratorio' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-mortarboard me-2"></i>
                    <span x-show="sidebarOpen">Laboratório</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/cadastros/semestres" class="nav-link text-white {% if active_menu == 'semestres' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-calendar-range me-2"></i>
                    <span x-show="sidebarOpen">Semestres</span>
                </a>
            </li>

            <li class="nav-item mt-2">
                <small class="text-secondary px-2" x-show="sidebarOpen">RELATÓRIOS</small>
            </li>
            <li class="nav-item">
                <a href="/relatorios" class="nav-link text-white {% if active_menu == 'relatorios' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-bar-chart me-2"></i>
                    <span x-show="sidebarOpen">Relatórios</span>
                </a>
            </li>

            {% if usuario_perfil == 'admin' %}
            <li class="nav-item mt-2">
                <small class="text-secondary px-2" x-show="sidebarOpen">ADMINISTRAÇÃO</small>
            </li>
            <li class="nav-item">
                <a href="/usuarios" class="nav-link text-white {% if active_menu == 'usuarios' %}active bg-primary rounded{% endif %}">
                    <i class="bi bi-person-gear me-2"></i>
                    <span x-show="sidebarOpen">Usuários</span>
                </a>
            </li>
            {% endif %}
        </ul>

        <div class="p-3 border-top border-secondary">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-person-circle fs-5"></i>
                <div x-show="sidebarOpen">
                    <div class="small fw-bold">{{ usuario_nome ?? 'Usuário' }}</div>
                    <div class="text-muted" style="font-size:0.7rem">{{ usuario_perfil ?? '' }}</div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Conteúdo principal -->
    <div class="flex-grow-1 d-flex flex-column min-vh-100">

        <!-- Topbar -->
        <header class="topbar bg-white border-bottom shadow-sm px-3 py-2 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary" @click="sidebarOpen = !sidebarOpen">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 small">
                        {% block breadcrumb %}
                        <li class="breadcrumb-item active">Dashboard</li>
                        {% endblock %}
                    </ol>
                </nav>
            </div>

            <div class="d-flex align-items-center gap-3">
                <!-- Semestre ativo -->
                {% if semestre_ref is defined %}
                <span class="badge bg-success">{{ semestre_ref }}</span>
                {% endif %}

                <!-- Ações rápidas -->
                <div class="dropdown">
                    <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>{{ usuario_nome ?? 'Usuário' }}
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><span class="dropdown-item-text text-muted small">{{ usuario_perfil }}</span></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form action="/logout" method="POST" class="m-0">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token ?? '' }}">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sair
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Área de conteúdo -->
        <main class="flex-grow-1 p-4">

            <!-- Flash messages -->
            {% if flash_success is defined and flash_success %}
            <div class="alert alert-success alert-dismissible fade show" role="alert" x-data x-init="setTimeout(() => $el.remove(), 5000)">
                <i class="bi bi-check-circle me-2"></i>{{ flash_success }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endif %}

            {% if flash_error is defined and flash_error %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>{{ flash_error }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endif %}

            {% block content %}{% endblock %}
        </main>

        <footer class="text-center text-muted small py-2 border-top bg-white">
            {{ app_name }} &copy; {{ "now"|date("Y") }} — Sistema de Agendamento Odontológico
        </footer>
    </div>
</div>

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Alpine.js 3 -->
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<!-- App JS -->
<script src="{{ app_url }}/js/app.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
