{% extends "layout/base.html.twig" %}

{% block title %}{{ modo == 'criar' ? 'Nova Turma' : 'Editar Turma' }} — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item">Cadastros</li>
<li class="breadcrumb-item"><a href="/cadastros/turmas">Turmas</a></li>
<li class="breadcrumb-item active">{{ modo == 'criar' ? 'Nova' : 'Editar' }}</li>
{% endblock %}

{% block content %}
<div class="row justify-content-center">
<div class="col-12 col-xl-9">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-people me-2 text-primary"></i>
            {{ modo == 'criar' ? 'Nova Turma' : 'Editar: ' ~ turma.nome|default('')|e }}
        </h4>
        <a href="/cadastros/turmas" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Voltar
        </a>
    </div>

    {% if errors is defined and errors %}
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Corrija os erros abaixo antes de continuar:</strong>
        <ul class="mb-0 mt-2">
            {% for field, msg in errors %}
            <li>{{ msg|e }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    <form action="{{ modo == 'criar' ? '/cadastros/turmas' : '/cadastros/turmas/' ~ turma.id }}"
          method="POST"
          novalidate
          x-data="{
              numeroAlunos: {{ turma.numero_alunos|default(0) }},
              temRestricoes: {{ turma.tem_restricoes|default(false) ? 'true' : 'false' }},
              diasBloqueados: {{ turma.dias_bloqueados|default([])|json_encode|raw }}
          }">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <!-- Dados da Turma -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-primary mb-3">Dados da Turma</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nome da Turma <span class="text-danger">*</span></label>
                        <input type="text"
                               class="form-control {{ errors.nome is defined ? 'is-invalid' : '' }}"
                               name="nome"
                               value="{{ turma.nome|default('')|e }}"
                               placeholder="Ex: OD-2022-MANHA"
                               maxlength="100"
                               required>
                        {% if errors.nome is defined %}
                        <div class="invalid-feedback">{{ errors.nome|e }}</div>
                        {% endif %}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Curso <span class="text-danger">*</span></label>
                        <select class="form-select {{ errors.curso_id is defined ? 'is-invalid' : '' }}"
                                name="curso_id" required>
                            <option value="">Selecione o curso...</option>
                            {% for curso in cursos %}
                            <option value="{{ curso.id }}"
                                    {{ turma.curso_id|default('') == curso.id ? 'selected' : '' }}>
                                {{ curso.nome|e }}
                            </option>
                            {% endfor %}
                        </select>
                        {% if errors.curso_id is defined %}
                        <div class="invalid-feedback">{{ errors.curso_id|e }}</div>
                        {% endif %}
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Período <span class="text-danger">*</span></label>
                        <select class="form-select {{ errors.periodo is defined ? 'is-invalid' : '' }}"
                                name="periodo" required>
                            <option value="">Selecione...</option>
                            {% for p in 1..10 %}
                            <option value="{{ p }}"
                                    {{ turma.periodo|default('') == p ? 'selected' : '' }}>
                                {{ p }}º Período
                            </option>
                            {% endfor %}
                        </select>
                        {% if errors.periodo is defined %}
                        <div class="invalid-feedback">{{ errors.periodo|e }}</div>
                        {% endif %}
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Número de Alunos <span class="text-danger">*</span></label>
                        <input type="number"
                               class="form-control {{ errors.numero_alunos is defined ? 'is-invalid' : '' }}"
                               name="numero_alunos"
                               x-model.number="numeroAlunos"
                               value="{{ turma.numero_alunos|default('')|e }}"
                               min="1" max="30" required>
                        <div class="form-text" x-show="numeroAlunos > 25 && numeroAlunos <= 30">
                            <i class="bi bi-exclamation-triangle-fill text-warning"></i>
                            <span class="text-warning fw-semibold">Atenção:</span> próximo ao limite de 30 alunos da clínica.
                        </div>
                        {% if errors.numero_alunos is defined %}
                        <div class="invalid-feedback">{{ errors.numero_alunos|e }}</div>
                        {% endif %}
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <div class="alert alert-info mb-0 py-2 w-100 small">
                            <i class="bi bi-info-circle me-1"></i>
                            Capacidade máxima: <strong>30 alunos</strong> (clínica e laboratório).
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Restrições de Horário -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-primary mb-3">Restrições de Horário</h6>

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="tem_restricoes"
                           name="tem_restricoes" value="1"
                           x-model="temRestricoes"
                           {{ turma.tem_restricoes|default(false) ? 'checked' : '' }}>
                    <label class="form-check-label fw-semibold" for="tem_restricoes">
                        Esta turma tem restrições de horário?
                    </label>
                </div>

                <div x-show="temRestricoes" x-transition>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Dias Bloqueados</label>
                            <div class="d-flex flex-wrap gap-3">
                                {% set dias = ['Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'] %}
                                {% set diasValues = ['seg', 'ter', 'qua', 'qui', 'sex', 'sab'] %}
                                {% for i in 0..5 %}
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="dias_bloqueados[]"
                                           id="dia_{{ diasValues[i] }}"
                                           value="{{ diasValues[i] }}"
                                           {{ turma.dias_bloqueados is defined and diasValues[i] in turma.dias_bloqueados ? 'checked' : '' }}>
                                    <label class="form-check-label" for="dia_{{ diasValues[i] }}">
                                        {{ dias[i] }}
                                    </label>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="col-md-4">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Observações sobre as restrições</label>
                            <textarea class="form-control" name="restricao_observacoes" rows="2"
                                      maxlength="500"
                                      placeholder="Descreva as restrições de horário desta turma...">{{ turma.restricao_observacoes|default('')|e }}</textarea>
                        </div>
                    </div>
                </div>

                <div x-show="!temRestricoes" class="text-muted small">
                    <i class="bi bi-check-circle text-success me-1"></i>
                    Sem restrições — a turma pode ser agendada em qualquer horário disponível.
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a href="/cadastros/turmas" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>
                {{ modo == 'criar' ? 'Criar Turma' : 'Salvar Alterações' }}
            </button>
        </div>
    </form>

</div>
</div>
{% endblock %}
