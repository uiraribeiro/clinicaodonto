{% extends "layout/base.html.twig" %}

{% block title %}Turmas — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item">Cadastros</li>
<li class="breadcrumb-item active">Turmas</li>
{% endblock %}

{% block content %}
<div x-data="{
    busca: '',
    periodo: '',
    curso: '',
    turmas: {{ turmas|json_encode }},
    get filtradas() {
        return this.turmas.filter(t => {
            const okBusca = this.busca === '' || t.nome.toLowerCase().includes(this.busca.toLowerCase());
            const okPeriodo = this.periodo === '' || String(t.periodo) === this.periodo;
            const okCurso = this.curso === '' || t.curso_nome.toLowerCase().includes(this.curso.toLowerCase());
            return okBusca && okPeriodo && okCurso;
        });
    }
}">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-people me-2 text-primary"></i>Turmas
        </h4>
        <a href="/cadastros/turmas/nova" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nova Turma
        </a>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Buscar por nome..."
                               x-model="busca">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm" x-model="periodo">
                        <option value="">Todos os períodos</option>
                        {% for p in 1..10 %}
                        <option value="{{ p }}">{{ p }}º Período</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" class="form-control form-control-sm"
                           placeholder="Filtrar por curso..."
                           x-model="curso">
                </div>
                <div class="col-md-1 text-end">
                    <button class="btn btn-sm btn-outline-secondary" @click="busca=''; periodo=''; curso=''">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Turma</th>
                            <th>Curso</th>
                            <th class="text-center">Período</th>
                            <th>Disciplina</th>
                            <th class="text-center">Nº Alunos</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="t in filtradas" :key="t.id">
                            <tr>
                                <td class="fw-semibold" x-text="t.nome"></td>
                                <td x-text="t.curso_nome"></td>
                                <td class="text-center">
                                    <span class="badge bg-secondary" x-text="t.periodo + 'º'"></span>
                                </td>
                                <td>
                                    <span class="fw-semibold small" x-text="t.disciplina_nome || '—'"></span>
                                    <span class="text-muted small ms-1" x-show="t.disciplina_codigo" x-text="'(' + t.disciplina_codigo + ')'"></span>
                                </td>
                                <td class="text-center">
                                    <span :class="t.numero_alunos > 25 ? 'badge bg-warning text-dark' : 'badge bg-light text-dark border'"
                                          x-text="t.numero_alunos">
                                    </span>
                                    <i class="bi bi-exclamation-triangle-fill text-warning ms-1"
                                       x-show="t.numero_alunos > 25"
                                       title="Próximo ao limite de 30 da clínica"></i>
                                </td>
                                <td class="text-center">
                                    <span :class="t.ativo ? 'badge bg-success' : 'badge bg-secondary'"
                                          x-text="t.ativo ? 'Ativa' : 'Inativa'"></span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a :href="'/cadastros/turmas/' + t.id" class="btn btn-outline-secondary" title="Visualizar">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a :href="'/cadastros/turmas/' + t.id + '/editar'" class="btn btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger" title="Excluir"
                                                @click="if(confirm('Excluir a turma ' + t.nome + '? Esta ação não pode ser desfeita.')) { document.getElementById('del-turma-' + t.id).submit(); }">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    <form :id="'del-turma-' + t.id"
                                          :action="'/cadastros/turmas/' + t.id + '/excluir'"
                                          method="POST" class="d-none">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    </form>
                                </td>
                            </tr>
                        </template>
                        <tr x-show="filtradas.length === 0">
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                Nenhuma turma encontrada com os filtros aplicados.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted small">
            <span x-text="filtradas.length"></span> turma(s) encontrada(s)
            <span x-show="filtradas.length !== turmas.length"> (de <span x-text="turmas.length"></span> no total)</span>
        </div>
    </div>

</div>
{% endblock %}
