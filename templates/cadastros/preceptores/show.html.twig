{% extends "layout/base.html.twig" %}

{% block title %}{{ preceptor.nome|e }} — Preceptores — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item">Cadastros</li>
<li class="breadcrumb-item"><a href="/cadastros/preceptores">Preceptores</a></li>
<li class="breadcrumb-item active">{{ preceptor.nome|e }}</li>
{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-person-check me-2 text-primary"></i>{{ preceptor.nome|e }}
        </h4>
        <small class="text-muted">Dados do preceptor</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/cadastros/preceptores" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Voltar
        </a>
        <a href="/cadastros/preceptores/{{ preceptor.id }}/editar" class="btn btn-primary">
            <i class="bi bi-pencil me-2"></i>Editar
        </a>
        <form action="/cadastros/preceptores/{{ preceptor.id }}/desativar" method="POST" class="d-inline">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit"
                    class="btn btn-outline-warning"
                    data-confirm="{{ preceptor.ativo ? 'Desativar o preceptor ' ~ preceptor.nome|e ~ '?' : 'Ativar o preceptor ' ~ preceptor.nome|e ~ '?' }}">
                <i class="bi {{ preceptor.ativo ? 'bi-person-x' : 'bi-person-check' }} me-1"></i>
                {{ preceptor.ativo ? 'Desativar' : 'Ativar' }}
            </button>
        </form>
        <form action="/cadastros/preceptores/{{ preceptor.id }}/excluir" method="POST" class="d-inline">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit"
                    class="btn btn-danger"
                    data-confirm="Excluir permanentemente o preceptor {{ preceptor.nome|e }}? Esta ação não pode ser desfeita.">
                <i class="bi bi-trash me-1"></i>Excluir
            </button>
        </form>
    </div>
</div>

<div class="row g-4">

    <!-- Card: Dados do preceptor -->
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-person-circle me-2 text-primary"></i>Identificação
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted small">Nome</dt>
                    <dd class="col-sm-7 fw-semibold">{{ preceptor.nome|e }}</dd>

                    <dt class="col-sm-5 text-muted small">E-mail</dt>
                    <dd class="col-sm-7">
                        <a href="mailto:{{ preceptor.email|e }}" class="text-decoration-none">{{ preceptor.email|e }}</a>
                    </dd>

                    <dt class="col-sm-5 text-muted small">Telefone</dt>
                    <dd class="col-sm-7">{{ preceptor.telefone|default('—')|e }}</dd>

                    <dt class="col-sm-5 text-muted small">Matrícula</dt>
                    <dd class="col-sm-7">
                        {% if preceptor.matricula is defined and preceptor.matricula %}
                        <code>{{ preceptor.matricula|e }}</code>
                        {% else %}
                        <span class="text-muted">—</span>
                        {% endif %}
                    </dd>

                    <dt class="col-sm-5 text-muted small">Máx. turmas simult.</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-warning text-dark fs-6">
                            {{ preceptor.max_turmas_simultaneas|default(2) }}
                        </span>
                    </dd>

                    <dt class="col-sm-5 text-muted small">Status</dt>
                    <dd class="col-sm-7">
                        <span class="badge {{ preceptor.ativo ? 'bg-success' : 'bg-secondary' }}">
                            {{ preceptor.ativo ? 'Ativo' : 'Inativo' }}
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Card: Disciplinas de estágio vinculadas -->
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-mortarboard me-2 text-primary"></i>Disciplinas de Estágio
            </div>
            <div class="card-body">
                {% if preceptor.disciplinas is defined and preceptor.disciplinas %}
                    <div class="d-flex flex-wrap gap-2">
                        {% for disc in preceptor.disciplinas %}
                        <a href="/cadastros/disciplinas/{{ disc.id }}"
                           class="badge bg-success text-decoration-none fs-6 fw-normal"
                           title="{{ disc.nome|e }}">
                            {{ disc.nome|e }}
                        </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-mortarboard fs-3 d-block mb-2 opacity-50"></i>
                        Nenhuma disciplina de estágio vinculada.
                    </div>
                {% endif %}

                <div class="mt-3 pt-3 border-top">
                    <a href="/cadastros/professor_disciplina?preceptor={{ preceptor.id }}" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-link-45deg me-1"></i>Gerenciar vínculos de estágio
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Card: Resumo rápido -->
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-bar-chart me-2 text-primary"></i>Resumo
            </div>
            <div class="card-body">
                <div class="row g-3 text-center">
                    <div class="col-6">
                        <div class="fs-2 fw-bold text-success">{{ preceptor.disciplinas_count|default(0) }}</div>
                        <div class="text-muted small">Estágios</div>
                    </div>
                    <div class="col-6">
                        <div class="fs-2 fw-bold text-warning">{{ preceptor.max_turmas_simultaneas|default(2) }}</div>
                        <div class="text-muted small">Máx. turmas</div>
                    </div>
                    <div class="col-12">
                        <div class="fs-2 fw-bold text-info">
                            {% if preceptor.disponibilidades is defined %}
                                {{ preceptor.disponibilidades|length }}
                            {% else %}
                                0
                            {% endif %}
                        </div>
                        <div class="text-muted small">Disponibilidades cadastradas</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Card: Disponibilidade semanal -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-calendar-week me-2 text-primary"></i>Disponibilidade Semanal
            </div>
            <div class="card-body">
                {% if preceptor.disponibilidades is defined and preceptor.disponibilidades %}
                    {% set dias_label = {1: 'Segunda', 2: 'Terça', 3: 'Quarta', 4: 'Quinta', 5: 'Sexta', 6: 'Sábado'} %}
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Dia</th>
                                    <th>Hora início</th>
                                    <th>Hora fim</th>
                                    <th class="text-center">Semana início</th>
                                    <th class="text-center">Semana fim</th>
                                    <th class="text-center">Período</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for disp in preceptor.disponibilidades %}
                            <tr>
                                <td>
                                    <span class="badge {{ disp.dia_semana == 6 ? 'bg-warning text-dark' : 'bg-info text-dark' }}">
                                        {{ dias_label[disp.dia_semana]|default('Dia ' ~ disp.dia_semana) }}
                                    </span>
                                </td>
                                <td class="fw-semibold">{{ disp.hora_inicio|e }}</td>
                                <td class="fw-semibold">{{ disp.hora_fim|e }}</td>
                                <td class="text-center">Sem. {{ disp.semana_inicio|e }}</td>
                                <td class="text-center">Sem. {{ disp.semana_fim|e }}</td>
                                <td class="text-center text-muted small">
                                    Sems. {{ disp.semana_inicio }}&ndash;{{ disp.semana_fim }}
                                </td>
                            </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-calendar-x fs-3 d-block mb-2 opacity-50"></i>
                        Nenhuma disponibilidade cadastrada.
                        <a href="/cadastros/preceptores/{{ preceptor.id }}/editar" class="d-block mt-2 small">
                            Adicionar disponibilidade
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

</div>

{% endblock %}
