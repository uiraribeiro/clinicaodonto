{% extends "layout/base.html.twig" %}

{% block title %}Semestres — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item">Cadastros</li>
<li class="breadcrumb-item active">Semestres</li>
{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="bi bi-calendar-range me-2 text-primary"></i>Semestres
    </h4>
    <a href="/cadastros/semestres/novo" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Novo Semestre
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Referência</th>
                        <th>Data Início</th>
                        <th>Data Fim</th>
                        <th class="text-center">Semanas</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% for s in semestres %}
                    <tr>
                        <td class="fw-bold">{{ s.referencia|e }}</td>
                        <td>{{ s.data_inicio|date('d/m/Y') }}</td>
                        <td>{{ s.data_fim|date('d/m/Y') }}</td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border">{{ s.numero_semanas }}</span>
                        </td>
                        <td class="text-center">
                            {% if s.status == 'ativo' %}
                            <span class="badge bg-success">Ativo</span>
                            {% elseif s.status == 'planejamento' %}
                            <span class="badge bg-warning text-dark">Planejamento</span>
                            {% elseif s.status == 'encerrado' %}
                            <span class="badge bg-secondary">Encerrado</span>
                            {% else %}
                            <span class="badge bg-light text-dark border">{{ s.status|capitalize|e }}</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/cadastros/semestres/{{ s.id }}" class="btn btn-outline-secondary" title="Visualizar">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/cadastros/semestres/{{ s.id }}/editar" class="btn btn-outline-primary" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                {% if s.status == 'planejamento' %}
                                <form action="/cadastros/semestres/{{ s.id }}/ativar" method="POST"
                                      onsubmit="return confirm('Ativar o semestre {{ s.referencia|e }}? Esta ação desativará o semestre atual.')">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Ativar">
                                        <i class="bi bi-play-circle"></i>
                                    </button>
                                </form>
                                {% endif %}
                                {% if s.status == 'planejamento' %}
                                <form action="/cadastros/semestres/{{ s.id }}/excluir" method="POST"
                                      onsubmit="return confirm('Excluir o semestre {{ s.referencia|e }}? Esta ação não pode ser desfeita.')">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-calendar-x fs-3 d-block mb-2 opacity-50"></i>
                            Nenhum semestre cadastrado.
                            <a href="/cadastros/semestres/novo" class="d-block mt-2">Criar o primeiro semestre</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}
