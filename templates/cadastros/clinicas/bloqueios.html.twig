{% extends "layout/base.html.twig" %}

{% block title %}Bloqueios — Clínica — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item">Cadastros</li>
<li class="breadcrumb-item"><a href="/cadastros/clinica">Clínica</a></li>
<li class="breadcrumb-item active">Bloqueios</li>
{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="bi bi-slash-circle me-2 text-warning"></i>Bloqueios — Clínica
    </h4>
    <a href="/cadastros/clinica" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="row g-4">

    <!-- Formulário de Adição -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold border-bottom">
                <i class="bi bi-plus-circle text-warning me-2"></i>Adicionar Bloqueio
            </div>
            <div class="card-body"
                 x-data="{ diaInteiro: true }">
                <form action="/cadastros/clinicas/{{ clinica.id }}/bloqueios"
                      method="POST" novalidate>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tipo <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm {{ errors.tipo is defined ? 'is-invalid' : '' }}"
                                name="tipo" required>
                            <option value="">Selecione...</option>
                            <option value="feriado"   {{ bloqueio.tipo|default('') == 'feriado'    ? 'selected' : '' }}>Feriado</option>
                            <option value="recesso"   {{ bloqueio.tipo|default('') == 'recesso'    ? 'selected' : '' }}>Recesso</option>
                            <option value="evento"    {{ bloqueio.tipo|default('') == 'evento'     ? 'selected' : '' }}>Evento</option>
                            <option value="manutencao" {{ bloqueio.tipo|default('') == 'manutencao' ? 'selected' : '' }}>Manutenção</option>
                        </select>
                        {% if errors.tipo is defined %}
                        <div class="invalid-feedback">{{ errors.tipo|e }}</div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Data Início <span class="text-danger">*</span></label>
                        <input type="date"
                               class="form-control form-control-sm {{ errors.data_inicio is defined ? 'is-invalid' : '' }}"
                               name="data_inicio"
                               value="{{ bloqueio.data_inicio|default('')|e }}"
                               required>
                        {% if errors.data_inicio is defined %}
                        <div class="invalid-feedback">{{ errors.data_inicio|e }}</div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Data Fim <span class="text-danger">*</span></label>
                        <input type="date"
                               class="form-control form-control-sm {{ errors.data_fim is defined ? 'is-invalid' : '' }}"
                               name="data_fim"
                               value="{{ bloqueio.data_fim|default('')|e }}"
                               required>
                        {% if errors.data_fim is defined %}
                        <div class="invalid-feedback">{{ errors.data_fim|e }}</div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox"
                                   id="dia_inteiro" x-model="diaInteiro" checked>
                            <label class="form-check-label" for="dia_inteiro">Dia inteiro</label>
                        </div>
                    </div>

                    <div x-show="!diaInteiro" x-transition>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label fw-semibold small">Hora Início</label>
                                <input type="time" class="form-control form-control-sm"
                                       name="hora_inicio"
                                       value="{{ bloqueio.hora_inicio|default('')|e }}">
                                <div class="form-text small">Vazio = dia inteiro</div>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold small">Hora Fim</label>
                                <input type="time" class="form-control form-control-sm"
                                       name="hora_fim"
                                       value="{{ bloqueio.hora_fim|default('')|e }}">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Motivo <span class="text-danger">*</span></label>
                        <input type="text"
                               class="form-control form-control-sm {{ errors.motivo is defined ? 'is-invalid' : '' }}"
                               name="motivo"
                               value="{{ bloqueio.motivo|default('')|e }}"
                               maxlength="300"
                               placeholder="Ex: Feriado Nacional, Semana Odontológica..."
                               required>
                        {% if errors.motivo is defined %}
                        <div class="invalid-feedback">{{ errors.motivo|e }}</div>
                        {% endif %}
                    </div>

                    <button type="submit" class="btn btn-warning w-100">
                        <i class="bi bi-plus-lg me-2"></i>Adicionar Bloqueio
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Lista de Bloqueios -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold border-bottom">
                <i class="bi bi-list-ul me-2"></i>Bloqueios Cadastrados
            </div>
            <div class="card-body p-0">
                {% if bloqueios is defined and bloqueios %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tipo</th>
                                <th>Data Início</th>
                                <th>Data Fim</th>
                                <th>Horário</th>
                                <th>Motivo</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for b in bloqueios %}
                            <tr>
                                <td>
                                    {% set tipoCores = {'feriado': 'danger', 'recesso': 'warning', 'evento': 'info', 'manutencao': 'secondary'} %}
                                    <span class="badge bg-{{ tipoCores[b.tipo] ?? 'secondary' }}">
                                        {{ b.tipo|capitalize|e }}
                                    </span>
                                </td>
                                <td>{{ b.data_inicio|date('d/m/Y') }}</td>
                                <td>{{ b.data_fim|date('d/m/Y') }}</td>
                                <td>
                                    {% if b.hora_inicio %}
                                    <span class="text-nowrap">{{ b.hora_inicio }} – {{ b.hora_fim }}</span>
                                    {% else %}
                                    <span class="badge bg-light text-dark border">Dia inteiro</span>
                                    {% endif %}
                                </td>
                                <td>{{ b.motivo|e }}</td>
                                <td class="text-center">
                                    <form action="/cadastros/clinicas/{{ clinica.id }}/bloqueios/{{ b.id }}/excluir"
                                          method="POST"
                                          onsubmit="return confirm('Excluir o bloqueio de {{ b.data_inicio|date('d/m/Y') }}?')">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="text-center text-muted py-5">
                    <i class="bi bi-check-circle fs-3 d-block mb-2 text-success opacity-75"></i>
                    Nenhum bloqueio cadastrado.
                </div>
                {% endif %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
