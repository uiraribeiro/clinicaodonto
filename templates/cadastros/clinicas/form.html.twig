{% extends "layout/base.html.twig" %}

{% block title %}Editar Clínica — {{ app_name }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item">Cadastros</li>
<li class="breadcrumb-item"><a href="/cadastros/clinica">Clínica</a></li>
<li class="breadcrumb-item active">Editar</li>
{% endblock %}

{% block content %}
<div class="row justify-content-center">
<div class="col-12 col-xl-9">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-hospital me-2 text-primary"></i>Editar Clínica
        </h4>
        <a href="/cadastros/clinica" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Voltar
        </a>
    </div>

    {% if errors is defined and errors %}
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Corrija os erros abaixo antes de continuar:</strong>
        <ul class="mb-0 mt-2">
            {% for field, msg in errors %}
            <li>{{ msg|e }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    <form action="/cadastros/clinicas/{{ clinica.id }}"
          method="POST"
          novalidate
          x-data="{
              cadeiras: {{ clinica.quantidade_cadeiras|default(15) }},
              porCadeira: {{ clinica.capacidade_por_cadeira|default(2) }},
              get total() { return this.cadeiras * this.porCadeira; }
          }">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <!-- Identificação -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-primary mb-3">Identificação</h6>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
                        <input type="text"
                               class="form-control {{ errors.nome is defined ? 'is-invalid' : '' }}"
                               name="nome"
                               value="{{ clinica.nome|default('')|e }}"
                               maxlength="200"
                               required>
                        {% if errors.nome is defined %}
                        <div class="invalid-feedback">{{ errors.nome|e }}</div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Capacidade -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-primary mb-3">Capacidade</h6>
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Quantidade de Cadeiras <span class="text-danger">*</span></label>
                        <input type="number"
                               class="form-control {{ errors.quantidade_cadeiras is defined ? 'is-invalid' : '' }}"
                               name="quantidade_cadeiras"
                               x-model.number="cadeiras"
                               min="1" max="30" required>
                        {% if errors.quantidade_cadeiras is defined %}
                        <div class="invalid-feedback">{{ errors.quantidade_cadeiras|e }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Alunos por Cadeira <span class="text-danger">*</span></label>
                        <input type="number"
                               class="form-control {{ errors.capacidade_por_cadeira is defined ? 'is-invalid' : '' }}"
                               name="capacidade_por_cadeira"
                               x-model.number="porCadeira"
                               min="1" max="5" required>
                        {% if errors.capacidade_por_cadeira is defined %}
                        <div class="invalid-feedback">{{ errors.capacidade_por_cadeira|e }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Capacidade Total (calculada)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-people"></i></span>
                            <input type="text" class="form-control fw-bold bg-light"
                                   :value="total + ' alunos'" readonly>
                        </div>
                        <div class="form-text" :class="total >= 28 ? 'text-success' : 'text-warning'">
                            <template x-if="total >= 28">
                                <span><i class="bi bi-check-circle-fill"></i> Capacidade plena atingida</span>
                            </template>
                            <template x-if="total < 28">
                                <span><i class="bi bi-exclamation-triangle"></i> Capacidade abaixo do recomendado (30)</span>
                            </template>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Horários -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-primary mb-3">Horários de Funcionamento</h6>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Segunda a Sexta</label>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Abertura <span class="text-danger">*</span></label>
                        <input type="time"
                               class="form-control {{ errors.hora_abertura is defined ? 'is-invalid' : '' }}"
                               name="hora_abertura"
                               value="{{ clinica.hora_abertura|default('07:00') }}"
                               required>
                        {% if errors.hora_abertura is defined %}
                        <div class="invalid-feedback">{{ errors.hora_abertura|e }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Fechamento <span class="text-danger">*</span></label>
                        <input type="time"
                               class="form-control {{ errors.hora_fechamento is defined ? 'is-invalid' : '' }}"
                               name="hora_fechamento"
                               value="{{ clinica.hora_fechamento|default('22:00') }}"
                               required>
                        {% if errors.hora_fechamento is defined %}
                        <div class="invalid-feedback">{{ errors.hora_fechamento|e }}</div>
                        {% endif %}
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted small text-uppercase mt-2">Sábado</label>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Abertura (Sáb)</label>
                        <input type="time"
                               class="form-control"
                               name="hora_abertura_sabado"
                               value="{{ clinica.hora_abertura_sabado|default('07:00') }}">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Fechamento (Sáb)</label>
                        <input type="time"
                               class="form-control"
                               name="hora_fechamento_sabado"
                               value="{{ clinica.hora_fechamento_sabado|default('12:00') }}">
                    </div>
                </div>
            </div>
        </div>

        <!-- Observações -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-primary mb-3">Observações</h6>
                <textarea class="form-control" name="observacoes" rows="3" maxlength="1000"
                          placeholder="Informações adicionais sobre a clínica...">{{ clinica.observacoes|default('')|e }}</textarea>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a href="/cadastros/clinica" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>Salvar Alterações
            </button>
        </div>
    </form>

</div>
</div>
{% endblock %}
